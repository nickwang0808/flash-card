{
  "name": "flash-card",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321 EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH expo start --web",
    "build": "expo export --platform web",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "validate:schema": "vitest run tests/unit/schema-validation.test.ts",
    "knip": "knip",
    "check": "tsc && knip",
    "seed": "npx tsx scripts/seed-test-repo.ts seed",
    "seed:reset": "npx tsx scripts/seed-test-repo.ts reset",
    "seed:status": "npx tsx scripts/seed-test-repo.ts status",
    "migrate:v2": "npx tsx scripts/migrate-v2.ts",
    "gen": "npx supabase gen types typescript --local > src/types/supabase.ts && npx tsx scripts/gen-rxdb-schemas.ts",
    "gen:prod": "npx supabase gen types typescript --project-id qfycxymncxuyexmwasgf > src/types/supabase.ts && npx tsx scripts/gen-rxdb-schemas.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~55.0.8",
    "expo-constants": "~55.0.9",
    "expo-router": "~55.0.7",
    "expo-speech": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "marked": "^17.0.5",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "rxdb": "^16.21.1",
    "tailwindcss": "~3.4.17",
    "ts-fsrs": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.2.0",
    "@types/react": "~19.2.2",
    "dotenv": "^17.2.3",
    "jsdom": "^25.0.0",
    "knip": "^5.83.1",
    "nativewind": "^4.1.23",
    "tailwindcss": "~3.4.17",
    "typescript": "~5.9.2",
    "vitest": "^2.1.0"
  }
}
